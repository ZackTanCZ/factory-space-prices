# MLflow tracking server
# Update this if running MLflow on a remote server
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=FYP-Factory-Price-Prediction
MLFLOW_MODEL_NAME=factory-price-prediction

# Alias for the champion model version in the MLflow registry
# Assign this alias in the MLflow UI after training
MLFLOW_CHAMPION_ALIAS=champion

# Backend URL — used by services that need to call the backend
# Update when deploying to a remote server
BACKEND_URL=http://localhost:8000

# Port mappings — used by Docker Compose for host-to-container port binding
BACKEND_PORT=8000
FRONTEND_PORT=8501
MLFLOW_PORT=5000

# Temporary directory for encoder serialisation during training
# Files are written here before being uploaded to MLflow, then deleted
TRAINING_TMP_DIR=models
